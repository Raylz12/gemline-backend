# Card Hedge (spine — start here)
# CARDHEDGE_AUTH=free          # 'free' for set-search only (no key needed)
# CARDHEDGE_AUTH=apikey        # keyed tier
# CARDHEDGE_API_KEY=your_key

# eBay Browse API (active asks)
# EBAY_CLIENT_ID=your_client_id
# EBAY_CLIENT_SECRET=your_client_secret

# Apify / Whatnot scraper
# APIFY_TOKEN=your_token
# APIFY_WHATNOT_ACTOR=actor_id

# Stripe Connect (payments + escrow)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Postgres (optional — in-memory by default)
# DATABASE_URL=postgresql://user:pass@host:5432/gemline

# Spread engine tuning
# ENRICH_LIMIT=20
# CACHE_TTL=300

PORT=8787
